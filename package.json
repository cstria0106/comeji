{
  "name": "comeji",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "pnpm run build:main && concurrently -k \"node .tools/dev-server.mjs\" \"wait-on .comeji/dev-server.json && electron . --dev\"",
    "build": "pnpm run prepare:codex && pnpm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "pnpm run update:codex && pnpm run typecheck && pnpm run build && electron-builder --win portable",
    "prepare:codex": "node scripts/prepare-codex.mjs",
    "start": "pnpm run build && electron .",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "update:codex": "pnpm add @openai/codex@latest && pnpm run prepare:codex"
  },
  "build": {
    "appId": "local.comeji.app",
    "productName": "Comeji",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "src/renderer/src/assets/character.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/codex",
        "to": "codex"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "Comeji-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@openai/codex": "^0.125.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  }
}
